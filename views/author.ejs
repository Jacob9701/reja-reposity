          </div>

          <div class="card">
            <i class="fa fa-mobile"></i>
            <h3>Mobile Design</h3>
            <p>Phone friendly</p>
          </div>

          <div class="card">
            <i class="fa fa-database"></i>
            <h3>Backend</h3>
            <p>Node.js / Express</p>
          </div>

          <div class="card">
            <i class="fa fa-camera"></i>
            <h3>Photography</h3>
            <p>Creative ideas</p>
          </div>

          <div class="card">
            <i class="fa fa-bullhorn"></i>
