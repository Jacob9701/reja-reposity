            <a href="https://t.me/jackhongrj" target="_blank">
              <i class="fa fa-telegram"></i>
            </a>

            <a href="https://github.com/jackhongrj" target="_blank">
              <i class="fa fa-github"></i>
            </a>

            <a href="https://linkedin.com" target="_blank">
